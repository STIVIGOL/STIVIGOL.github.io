"Sprite"
{
    "$basetexture" "damage/7"
    "$vertexcolor" "1"
    "$vertexalpha" "1"
    
    // Эти настройки гарантируют прозрачность и поворот к игроку
    "$spriteorientation" "vp_parallel"
    "$spriteorigin" "[0.50 0.50]"
    
    // Оставляем игнорирование стен, чтобы цифры были видны поверх врага
    "$ignorez" "1" 

    // Оставляем масштабирование, так как оно работает
    "Proxies"
    {
        "TextureTransform"
        {
            "scaleVar" "[4.0 4.0]" // Чем выше число, тем МЕНЬШЕ будет цифра
            "resultVar" "$basetexturetransform"
        }
    }
}